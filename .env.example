# Frontend
VITE_SUBMISSION_API_BASE=http://localhost:8000

# Backend
SUBMISSION_PROCESS_INLINE=true
SUBMISSION_API_ALLOWED_ORIGINS=http://localhost:5173
SUBMISSION_GITHUB_PR_DRY_RUN=true
SUBMISSION_TARGET_REPO_CLONE_URL=https://github.com/microsoft/Loopsbench.git
SUBMISSION_TARGET_REPO_OWNER=microsoft
SUBMISSION_TARGET_REPO_NAME=Loopsbench
SUBMISSION_TARGET_BASE_BRANCH=main

# Point this to a Python interpreter that can run the cloned LoopsBench CLI.
SUBMISSION_PYTHON_EXECUTABLE=/abs/path/to/python

# Required for contributor-authored PRs.
# SUBMISSION_GITHUB_OAUTH_CLIENT_ID=
# SUBMISSION_GITHUB_OAUTH_CLIENT_SECRET=
# SUBMISSION_GITHUB_OAUTH_REDIRECT_URL=http://localhost:8000/api/v1/github/callback
# SUBMISSION_SESSION_SECRET=replace-with-a-random-secret
# SUBMISSION_GITHUB_SESSION_COOKIE_SECURE=false
